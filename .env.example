# Local dev needs none of this — the app defaults to a local SQLite file at
# data/lodestar.db via libSQL's local-file engine.
#
# Set these two for a hosted deployment (e.g. Vercel) against a remote
# Turso/libSQL database instead:

# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
